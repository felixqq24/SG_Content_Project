wend---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Message sent · Riviera & Ridge"
  description="Thank you for your enquiry. We will be in touch within two working days."
>
  <head>
    <meta name="robots" content="noindex, nofollow" />
  </head>

  <Nav slot="header" />

  <section class="success-hero">
    <div class="container" style="text-align:center; max-width:640px; margin:0 auto;">
      <div class="checkmark">✓</div>
      <h1>Thank you.</h1>
      <p class="lead">
        Your message has been received. We will be in touch within two working
        days — typically with an invitation to a qualifying conversation.
      </p>
      <p>
        If you have an urgent question in the meantime, write to
        <a href="mailto:hello@rivieraandridge.com">hello@rivieraandridge.com</a>.
      </p>
      <a href="/" class="back-link">← Back to homepage</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .success-hero {
    background: var(--navy);
    color: var(--pearl);
    padding: 140px 0 120px;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .checkmark {
    width: 64px;
    height: 64px;
    border: 2px solid var(--gold);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: var(--gold);
    margin-bottom: 32px;
  }

  h1 {
    font-size: clamp(34px, 5vw, 48px);
    font-weight: 300;
    margin-bottom: 24px;
  }

  .lead {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(250, 246, 239, 0.85);
    margin-bottom: 16px;
  }

  p {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(250, 246, 239, 0.7);
    margin-bottom: 32px;
  }

  a {
    color: var(--gold);
  }

  .back-link {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(250, 246, 239, 0.6);
    text-decoration: none;
    border-bottom: 1px solid rgba(184, 137, 58, 0.3);
    padding-bottom: 4px;
    transition: color 0.3s;
  }

  .back-link:hover {
    color: var(--gold);
  }
</style>
