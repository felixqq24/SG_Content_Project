---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import contactImg from '../assets/images/contact.jpg';
---

<Base
  title="Contact · Premium Nanny Zermatt · Riviera & Ridge"
  description="Book a qualifying call with Riviera & Ridge. Premium nanny services in Zermatt — request a callback, send an enquiry or book directly."
>
  <Nav slot="header" />

  <!-- ═══════════ HERO ═══════════ -->
  <section class="page-hero">
    <div class="container">
      <h1>Every engagement begins <em>with a conversation.</em></h1>
      <p class="hero-lead">
        The qualifying conversation lets us understand your family — and lets
        you understand who you are entrusting your children to. It is unhurried,
        confidential, and without obligation.
      </p>
    </div>
  </section>

  <!-- ═══════════ OPTIONS ═══════════ -->
  <section class="options">
    <div class="container">
      <div class="options-grid">

        <a href="#enquiry" class="option-card">
          <div class="option-icon">✉</div>
          <h2>Send an enquiry</h2>
          <p>
            Prefer writing first? Send us the key details and we come back with
            next steps within two working days.
          </p>
          <span class="option-cta">Write to us →</span>
        </a>

        <a href="#callback" class="option-card">
          <div class="option-icon">☎</div>
          <h2>Request a callback</h2>
          <p>
            Leave your number and preferred time window. We call you back within
            two working days — discreetly, from a Swiss number.
          </p>
          <span class="option-cta">Request a callback →</span>
        </a>

        <a href="mailto:hello@rivieraandridge.com" class="option-card">
          <div class="option-icon">@</div>
          <h2>Write directly</h2>
          <p>
            Reach us at hello@rivieraandridge.com. We reply within two working
            days with next steps.
          </p>
          <span class="option-cta">Email us →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════ ENQUIRY FORM ═══════════ -->
  <section class="form-section" id="enquiry">
    <div class="container form-grid">
      <div class="form-content">
        <div class="eyebrow">Send an enquiry</div>
        <h2>Tell us about your family.</h2>
        <p>
          We respond within two working days with next steps — typically an
          invitation to a qualifying call.
        </p>

        <form
          name="enquiry"
          method="POST"
          action="/success"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="contact-form"
        >
          <input type="hidden" name="form-name" value="enquiry" />
          <p class="hidden" aria-hidden="true">
            <label>Do not fill this: <input name="bot-field" /></label>
          </p>

          <div class="form-row">
            <div class="form-group">
              <label for="name">Name *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="phone">Phone (optional)</label>
              <input type="tel" id="phone" name="phone" />
            </div>
            <div class="form-group">
              <label for="country">Country / current base *</label>
              <input type="text" id="country" name="country" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="children">Number and age of children *</label>
              <input type="text" id="children" name="children" required />
            </div>
            <div class="form-group">
              <label for="period">Approximate period of engagement</label>
              <input type="text" id="period" name="period" placeholder="e.g. 2 weeks in August" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="tier">Service tier most relevant</label>
              <select id="tier" name="tier">
                <option value="">Not sure yet</option>
                <option value="travel-alpine">Active Travel & Alpine</option>
                <option value="behavioral-harmony">Behavioral & Harmony Coaching</option>
                <option value="elite-relief">Elite Relief & Emergency</option>
              </select>
            </div>
            <div class="form-group">
              <label for="source">How did you find us?</label>
              <select id="source" name="source">
                <option value="">Prefer not to say</option>
                <option value="search">Search engine</option>
                <option value="agency">Agency referral</option>
                <option value="recommendation">Personal recommendation</option>
                <option value="social">Social media</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>

          <div class="form-group full">
            <label for="message">Anything specific we should know? (optional)</label>
            <textarea id="message" name="message" rows="4" maxlength="500"></textarea>
          </div>

          <div class="form-group full consent">
            <label>
              <input type="checkbox" name="consent-enquiry" required />
              I agree to the processing of my data for the purpose of this
              enquiry. I can withdraw consent at any time.
              <a href="/privacy">Privacy Policy</a>
            </label>
          </div>

          <button type="submit" class="submit-btn">Send enquiry</button>
        </form>
      </div>

      <div class="form-photo">
        <Image
          src={contactImg}
          alt="Contact — Riviera & Ridge"
          width={400}
          quality={80}
          format="webp"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════ CALLBACK FORM ═══════════ -->
  <section class="callback-section" id="callback">
    <div class="container narrow">
      <div class="eyebrow">Request a callback</div>
      <h2>We call you back within two working days.</h2>
      <p class="callback-intro">
        Leave a few details. We call from a Swiss number (+41). If you have a
        preferred time window, let us know.
      </p>

      <form
        name="callback"
        method="POST"
        action="/success"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="contact-form callback-form"
      >
        <input type="hidden" name="form-name" value="callback" />
        <p class="hidden" aria-hidden="true">
          <label>Do not fill this: <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <div class="form-group">
            <label for="cb-name">Name *</label>
            <input type="text" id="cb-name" name="name" required />
          </div>
          <div class="form-group">
            <label for="cb-phone">Phone number (with country code) *</label>
            <input type="tel" id="cb-phone" name="phone" required placeholder="+41 ..." />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="cb-time">Preferred time window</label>
            <select id="cb-time" name="time-window">
              <option value="no-preference">No preference</option>
              <option value="morning">Morning (9–12 CET)</option>
              <option value="afternoon">Afternoon (12–17 CET)</option>
              <option value="evening">Evening (17–19 CET)</option>
            </select>
          </div>
          <div class="form-group">
            <label for="cb-days">Preferred day(s)</label>
            <select id="cb-days" name="preferred-days">
              <option value="weekdays">Weekdays</option>
              <option value="saturday">Saturday</option>
              <option value="no-preference">No preference</option>
            </select>
          </div>
        </div>

        <div class="form-group full">
          <label for="cb-note">Brief note (optional)</label>
          <textarea id="cb-note" name="note" rows="2" maxlength="300"></textarea>
        </div>

        <div class="form-group full consent">
          <label>
            <input type="checkbox" name="consent-callback" required />
            I agree to the processing of my data for the purpose of this callback.
            <a href="/privacy">Privacy Policy</a>
          </label>
        </div>

        <button type="submit" class="submit-btn">Request callback</button>
      </form>
    </div>
  </section>

  <!-- ═══════════ DIRECT CONTACT ═══════════ -->
  <section class="direct">
    <div class="container narrow" style="text-align:center">
      <div class="eyebrow">Or reach us directly</div>
      <div class="direct-grid">
        <div class="direct-item">
          <h4>Email</h4>
          <p><a href="mailto:hello@rivieraandridge.com">hello@rivieraandridge.com</a></p>
          <p class="small">Reply within two working days.</p>
        </div>
        <div class="direct-item">
          <h4>Phone</h4>
          <p><a href="tel:+41783179889">+41 78 317 98 89</a></p>
          <p class="small">Mon–Fri, 9–18 CET</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ TRUST ═══════════ -->
  <section class="trust">
    <div class="container narrow" style="text-align:center">
      <p>
        Riviera &amp; Ridge is built around one qualified professional — and,
        when capacity requires it, a small circle of carefully chosen associates
        who work in the same spirit. When you write, call, or book, the
        conversation begins with the person who will be with your children.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .page-hero {
    background: var(--navy);
    color: var(--pearl);
    padding: 100px 0 80px;
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(34px, 5vw, 52px);
    font-weight: 300;
    max-width: 780px;
    margin: 0 auto 24px;
  }

  .page-hero h1 em { font-style: italic; color: #E8D9B5; font-weight: 300; }

  .hero-lead {
    font-size: 17px;
    color: rgba(250, 246, 239, 0.75);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── OPTIONS ── */
  .options { padding: 100px 0; }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .option-card {
    display: block;
    background: var(--pearl-card);
    padding: 44px 32px 36px;
    border-top: 2px solid var(--gold);
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .option-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(14, 26, 58, 0.07);
  }

  .option-icon {
    font-size: 28px;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .option-card h2 {
    font-size: 24px;
    color: var(--navy);
    margin-bottom: 14px;
  }

  .option-card p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .option-cta {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--purple);
    font-weight: 500;
  }

  /* ── FORM SECTION ── */
  .form-section { padding: 100px 0; background: var(--pearl-card); }

  .form-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .form-content .eyebrow { margin-bottom: 14px; }

  .form-content h2 {
    font-size: 34px;
    color: var(--navy);
    margin-bottom: 16px;
  }

  .form-content > p {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .form-photo img {
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center top;
    max-width: 100%;
    margin-top: 60px;
  }

  /* ── SHARED FORM STYLES ── */
  .hidden { display: none !important; }

  .contact-form {
    background: #fff;
    padding: 36px 32px;
    border: 1px solid rgba(14, 26, 58, 0.06);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-group { display: flex; flex-direction: column; }
  .form-group.full { margin-bottom: 20px; }

  label {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--navy);
    margin-bottom: 6px;
  }

  input, select, textarea {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    padding: 10px 14px;
    border: 1px solid rgba(14, 26, 58, 0.15);
    background: #fff;
    color: var(--navy);
    transition: border-color 0.2s;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  .consent label {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
    line-height: 1.6;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .consent input[type="checkbox"] {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .consent a {
    color: var(--purple);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .submit-btn {
    background: var(--navy);
    color: var(--pearl);
    border: none;
    padding: 16px 32px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.3s;
    margin-top: 10px;
  }

  .submit-btn:hover { background: var(--purple); }

  /* ── CALLBACK ── */
  .callback-section {
    padding: 100px 0;
  }

  .narrow {
    max-width: 720px;
    margin: 0 auto;
  }

  .callback-section .eyebrow { text-align: center; margin-bottom: 14px; }

  .callback-section h2 {
    font-size: 34px;
    color: var(--navy);
    margin-bottom: 16px;
    text-align: center;
  }

  .callback-intro {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    text-align: center;
    margin-bottom: 36px;
  }

  .callback-form {
    max-width: 720px;
  }

  /* ── DIRECT CONTACT ── */
  .direct {
    padding: 80px 0;
    background: var(--navy);
    color: var(--pearl);
  }

  .direct .eyebrow { color: var(--gold); margin-bottom: 32px; }

  .direct-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    max-width: 500px;
    margin: 0 auto;
  }

  .direct-item h4 {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    font-weight: 500;
  }

  .direct-item p {
    font-size: 15px;
    color: var(--pearl);
    margin-bottom: 4px;
  }

  .direct-item a {
    color: var(--pearl);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .direct-item .small {
    font-size: 12px;
    color: rgba(250, 246, 239, 0.6);
  }

  /* ── TRUST ── */
  .trust {
    padding: 70px 0;
    border-top: 1px solid var(--hairline);
  }

  .trust p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 880px) {
    .options-grid { grid-template-columns: 1fr; }
    .form-grid { grid-template-columns: 1fr; gap: 50px; }
    .form-photo { display: none; }
    .direct-grid { grid-template-columns: 1fr; text-align: left; }
  }

  @media (max-width: 540px) {
    .page-hero { padding: 70px 0 50px; }
    .page-hero h1 { font-size: 30px; }
    .options, .form-section, .callback-section { padding: 60px 0; }
    .form-row { grid-template-columns: 1fr; }
    .contact-form { padding: 24px 18px; }
  }
</style>
