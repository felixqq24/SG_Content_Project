---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="For Agencies · Riviera & Ridge"
  description="Book a qualified educator through your agency. Introductory call or direct placement briefing. One point of contact, clean hand-overs, full transparency."
>
  <Nav slot="header" />

  <!-- ═══════════ HERO ═══════════ -->
  <section class="page-hero">
    <div class="container">
      <div class="eyebrow">Placements via your agency</div>
      <h1>A qualified educator, <em>placed through channels you already trust.</em></h1>
      <p class="hero-lead">
        Riviera &amp; Ridge is available for placements via selected nanny and
        governess agencies. All contractual, logistical, and communication
        frames sit with your agency. We focus on the child.
      </p>
    </div>
  </section>

  <!-- ═══════════ PROFILE ═══════════ -->
  <section class="profile-section">
    <div class="container profile-grid">

      <div class="profile-content">
        <!-- TWO BOOKING TRACKS -->
        <h2>Two booking tracks</h2>

        <div class="track-cards">
          <div class="track-card">
            <h3>New agency: Introductory call</h3>
            <p class="track-for">For agencies exploring a collaboration for the first time.</p>
            <p>
              A 30-minute call to discuss how we might work together. We walk
              through qualifications, service tiers, availability windows, and
              your placement process.
            </p>
            <ul>
              <li>Mutual introduction and working style</li>
              <li>Which service tiers fit your client portfolio</li>
              <li>Availability windows and lead times</li>
              <li>Rates, invoicing, and contractual framework</li>
              <li>Communication preferences</li>
            </ul>
            <a href="mailto:agencies@rivieraandridge.com" class="track-cta">Book an introductory call →</a>
          </div>

          <div class="track-card">
            <h3>Returning partner: Placement briefing</h3>
            <p class="track-for">For agencies we have already worked with.</p>
            <p>
              A 15-minute placement briefing for a specific family. You share
              the brief, we confirm fit and availability.
            </p>
            <ul>
              <li>Family profile (location, children, languages)</li>
              <li>Engagement type and dates</li>
              <li>Tier most relevant</li>
              <li>Any particular needs or sensitivities</li>
              <li>Your preferred communication channel</li>
            </ul>
            <a href="mailto:agencies@rivieraandridge.com" class="track-cta">Book a placement briefing →</a>
          </div>
        </div>

        <!-- HOW WE WORK -->
        <h2>How we work with agencies</h2>

        <div class="collab-grid">
          <div class="collab-item">
            <h4>The qualifying step — always</h4>
            <p>
              Every placement includes a qualifying step. For new agencies, this is
              the introductory call. For returning partners, the placement briefing.
            </p>
          </div>
          <div class="collab-item">
            <h4>Collaboration model</h4>
            <p>
              Single placements, relief cover, or recurring engagements. One point of
              contact on each side. Full transparency on availability and rates.
            </p>
          </div>
          <div class="collab-item">
            <h4>Reciprocal visibility</h4>
            <p>
              Logo placement on both sides, subject to written agreement. Agencies
              may reference Riviera &amp; Ridge in their talent portfolio.
            </p>
          </div>
          <div class="collab-item">
            <h4>Response commitments</h4>
            <p>
              Introductory call &amp; placement briefing: confirmation within 24 h.
              Placement form: availability response within 1 working day.
              Urgent requests: same-day response (best effort).
            </p>
          </div>
        </div>

        <!-- PLACEMENT FORM -->
        <h2 id="placement-form">Prefer to send a brief in writing?</h2>
        <p class="form-intro">
          For agencies that work asynchronously or across time zones — submit a
          placement request and we respond within one working day.
        </p>

        <form
          name="agency-placement"
          method="POST"
          action="/success"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="placement-form"
        >
          <input type="hidden" name="form-name" value="agency-placement" />
          <p class="hidden" aria-hidden="true">
            <label>Do not fill this: <input name="bot-field" /></label>
          </p>

          <div class="form-row">
            <div class="form-group">
              <label for="agency">Agency name *</label>
              <input type="text" id="agency" name="agency" required />
            </div>
            <div class="form-group">
              <label for="contact-person">Contact person *</label>
              <input type="text" id="contact-person" name="contact-person" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone (optional)</label>
              <input type="tel" id="phone" name="phone" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="location">Family location / destination *</label>
              <input type="text" id="location" name="location" required />
            </div>
            <div class="form-group">
              <label for="children">Number and age of children *</label>
              <input type="text" id="children" name="children" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="engagement-type">Engagement type *</label>
              <select id="engagement-type" name="engagement-type" required>
                <option value="">Please select</option>
                <option value="weekly">Weekly</option>
                <option value="monthly">Monthly</option>
                <option value="relief">Relief / short-notice</option>
                <option value="ski-season">Ski season</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="dates">Preferred dates or period *</label>
              <input type="text" id="dates" name="dates" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="tier">Service tier most relevant</label>
              <select id="tier" name="tier">
                <option value="">Not sure</option>
                <option value="travel-alpine">Active Travel & Alpine</option>
                <option value="behavioral-harmony">Behavioral & Harmony Coaching</option>
                <option value="elite-relief">Elite Relief & Emergency</option>
              </select>
            </div>
            <div class="form-group">
              <label for="urgency">Urgency</label>
              <select id="urgency" name="urgency">
                <option value="standard">Standard (2+ weeks lead time)</option>
                <option value="urgent">Urgent (&lt; 2 weeks)</option>
              </select>
            </div>
          </div>

          <div class="form-group full">
            <label for="note">Brief note (optional)</label>
            <textarea id="note" name="note" rows="3" maxlength="300"></textarea>
          </div>

          <div class="form-group full consent">
            <label>
              <input type="checkbox" name="consent" required />
              I confirm that I have a legal basis to share this family's contact
              data and consent to its processing by Riviera &amp; Ridge for the
              purpose of this placement.
              <a href="/privacy">Privacy Policy</a>
            </label>
          </div>

          <button type="submit" class="submit-btn">Submit placement request</button>
        </form>
      </div>

      <!-- SIDEBAR PROFILE CARD -->
      <aside class="profile-sidebar">
        <div class="profile-card">
          <h4>At a glance</h4>
          <dl>
            <dt>Qualification</dt>
            <dd><em>Staatlich geprüfte Erzieherin</em> (state-certified, Germany)</dd>
            <dt>Additional</dt>
            <dd>Ski instructor · Yoga teacher (incl. children's yoga, 3HO) · First-aid</dd>
            <dt>Experience</dt>
            <dd>20+ years · Mother of four</dd>
            <dt>Languages</dt>
            <dd>EN (working) · DE · FR</dd>
            <dt>Base</dt>
            <dd>Zermatt, Switzerland</dd>
            <dt>Availability</dt>
            <dd>International, weekly &amp; monthly</dd>
            <dt>Service tiers</dt>
            <dd>I. Travel &amp; Alpine · II. Harmony Coaching · III. Relief &amp; Emergency</dd>
            <dt>Ski partner</dt>
            <dd>Evolution Ski School Zermatt</dd>
          </dl>
        </div>

        <div class="agency-contact">
          <h4>Agency contact</h4>
          <p><a href="mailto:agencies@rivieraandridge.com">agencies@rivieraandridge.com</a></p>
          <p>Mon–Fri, 9–18 CET</p>
        </div>
      </aside>

    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .page-hero {
    background: var(--navy);
    color: var(--pearl);
    padding: 100px 0 80px;
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(30px, 4.5vw, 48px);
    font-weight: 300;
    max-width: 820px;
    margin: 0 auto 24px;
  }

  .page-hero h1 em { font-style: italic; color: #E8D9B5; font-weight: 300; }
  .page-hero .eyebrow { margin-bottom: 20px; color: var(--gold); }

  .hero-lead {
    font-size: 17px;
    color: rgba(250, 246, 239, 0.75);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── PROFILE GRID ── */
  .profile-section { padding: 100px 0; }

  .profile-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .profile-content h2 {
    font-size: 28px;
    color: var(--navy);
    margin: 60px 0 24px;
  }

  .profile-content h2:first-child { margin-top: 0; }

  /* ── TRACK CARDS ── */
  .track-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .track-card {
    background: var(--pearl-card);
    border-top: 2px solid var(--gold);
    padding: 32px 28px;
  }

  .track-card h3 {
    font-size: 22px;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .track-for {
    font-size: 13px;
    color: var(--gold);
    font-style: italic;
    margin-bottom: 14px;
  }

  .track-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 14px;
  }

  .track-card ul { list-style: none; margin-bottom: 20px; }

  .track-card li {
    font-size: 13px;
    color: var(--text-muted);
    padding: 5px 0 5px 18px;
    position: relative;
    line-height: 1.5;
  }

  .track-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 8px;
    height: 1px;
    background: var(--gold);
  }

  .track-cta {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--purple);
    font-weight: 500;
  }

  /* ── COLLAB ── */
  .collab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .collab-item {
    padding: 24px;
    border-top: 1px solid var(--hairline);
  }

  .collab-item h4 {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 10px;
  }

  .collab-item p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* ── FORM ── */
  .form-intro {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 30px;
  }

  .placement-form {
    background: var(--pearl-card);
    padding: 40px 36px;
    border-top: 2px solid var(--gold);
  }

  .hidden { display: none !important; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-group { display: flex; flex-direction: column; }
  .form-group.full { margin-bottom: 20px; }

  label {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--navy);
    margin-bottom: 6px;
  }

  input, select, textarea {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    padding: 10px 14px;
    border: 1px solid rgba(14, 26, 58, 0.15);
    background: #fff;
    color: var(--navy);
    transition: border-color 0.2s;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  .consent label {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
    line-height: 1.6;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .consent input[type="checkbox"] {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .consent a {
    color: var(--purple);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .submit-btn {
    background: var(--navy);
    color: var(--pearl);
    border: none;
    padding: 16px 32px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.3s;
    margin-top: 10px;
  }

  .submit-btn:hover { background: var(--purple); }

  /* ── SIDEBAR ── */
  .profile-sidebar {
    position: sticky;
    top: 100px;
  }

  .profile-card {
    background: var(--navy);
    color: var(--pearl);
    padding: 36px 28px;
    border-top: 2px solid var(--gold);
    margin-bottom: 24px;
  }

  .profile-card h4 {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    font-weight: 500;
  }

  dl { display: grid; grid-template-columns: auto 1fr; gap: 8px 16px; }

  dt {
    font-size: 12px;
    font-weight: 500;
    color: rgba(250, 246, 239, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  dd {
    font-size: 13px;
    color: rgba(250, 246, 239, 0.9);
    line-height: 1.5;
  }

  dd em { font-style: italic; }

  .agency-contact {
    background: var(--pearl-card);
    padding: 28px;
    border-top: 2px solid var(--gold);
  }

  .agency-contact h4 {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 14px;
    font-weight: 500;
  }

  .agency-contact p {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .agency-contact a {
    color: var(--purple);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 880px) {
    .profile-grid { grid-template-columns: 1fr; gap: 50px; }
    .profile-sidebar { position: static; }
    .track-cards, .collab-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .page-hero { padding: 70px 0 50px; }
    .page-hero h1 { font-size: 28px; }
    .profile-section { padding: 60px 0; }
    .placement-form { padding: 28px 20px; }
  }
</style>
