---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Active Travel & Alpine · Riviera & Ridge"
  description="One constant wherever you travel. Weekly and monthly engagements in Zermatt or abroad. Ski accompaniment via Evolution Ski School Zermatt."
>
  <Nav slot="header" />

  <!-- ═══════════ HERO ═══════════ -->
  <section class="page-hero">
    <div class="container">
      <span class="tier-label">Tier I</span>
      <div class="eyebrow">For internationally mobile families</div>
      <h1>One constant, <em>wherever you travel.</em></h1>
      <p class="hero-lead">
        Weekly and monthly engagements, in Zermatt or abroad. For children who
        benefit from continuity, movement, and a calmer household rhythm.
      </p>
    </div>
  </section>

  <!-- ═══════════ WHAT THIS LOOKS LIKE ═══════════ -->
  <section class="detail">
    <div class="container detail-grid">
      <div class="detail-main">
        <h2>What this looks like</h2>
        <ul class="feature-list">
          <li>Week- or month-long engagements, single- or multi-location.</li>
          <li>One qualified educator as the constant reference for the children — continuity over rotation.</li>
          <li>Clear written brief: routines, languages, school, allergies, boundaries.</li>
          <li>Discreet coordination with existing household staff (housekeepers, drivers, tutors) where present.</li>
          <li>
            Ski accompaniment in Zermatt in partnership with
            <strong>Evolution Ski School Zermatt</strong> — qualified instruction
            through the ski school, patient care before, between, and after
            lessons through Riviera &amp; Ridge.
          </li>
          <li>Travel itinerary coordination: acclimatisation support, activity programming, outdoor competence across terrain and time zones.</li>
        </ul>

        <h2>Typical fit</h2>
        <ul class="feature-list">
          <li>Families based across several residences (e.g. Zurich · London · Dubai · Zermatt).</li>
          <li>Children aged roughly 3–14, single- or multilingual.</li>
          <li>Ski families in Zermatt who want a companion with alpine competence and pedagogical depth.</li>
          <li>Households that value a professional educator over a generalist.</li>
        </ul>
      </div>

      <aside class="detail-sidebar">
        <div class="sidebar-card">
          <h4>Indicative frame</h4>
          <ul>
            <li>Rates confirmed after the qualifying conversation</li>
            <li>Travel, accommodation &amp; per diems arranged separately</li>
            <li>Languages: EN · DE · FR</li>
          </ul>
          <a href="/contact" class="sidebar-cta">Request a conversation</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- ═══════════ PARTNER ═══════════ -->
  <section class="partner">
    <div class="container narrow">
      <div class="eyebrow">Alpine partnership</div>
      <h2>Evolution Ski School Zermatt</h2>
      <p>
        Ski instruction in Zermatt is delivered exclusively by
        <strong>Evolution Ski School Zermatt</strong> (Fabrizio Pavan).
        Riviera &amp; Ridge provides the care component: preparation,
        transitions, quiet time, and companionship on and off the snow.
      </p>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════ -->
  <section class="page-cta">
    <div class="container" style="text-align:center">
      <h2>A child who feels secure travels differently.</h2>
      <p>Every engagement begins with a qualifying conversation.</p>
      <a href="/contact" class="cta-btn">Request a conversation</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .page-hero {
    background: var(--navy);
    color: var(--pearl);
    padding: 100px 0 80px;
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(34px, 5vw, 52px);
    font-weight: 300;
    max-width: 780px;
    margin: 0 auto 24px;
  }

  .page-hero h1 em { font-style: italic; color: #E8D9B5; font-weight: 300; }
  .page-hero .eyebrow { margin-bottom: 20px; color: var(--gold); }

  .tier-label {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(184, 137, 58, 0.4);
    padding: 6px 18px;
    margin-bottom: 20px;
  }

  .hero-lead {
    font-size: 17px;
    color: rgba(250, 246, 239, 0.75);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── DETAIL ── */
  .detail { padding: 100px 0; }

  .detail-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .detail-main h2 {
    font-size: 28px;
    color: var(--navy);
    margin: 50px 0 24px;
  }

  .detail-main h2:first-child { margin-top: 0; }

  .feature-list {
    list-style: none;
  }

  .feature-list li {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-muted);
    padding: 10px 0 10px 24px;
    position: relative;
    border-bottom: 1px solid rgba(14, 26, 58, 0.06);
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20px;
    width: 10px;
    height: 1px;
    background: var(--gold);
  }

  /* ── SIDEBAR ── */
  .sidebar-card {
    background: var(--pearl-card);
    border-top: 2px solid var(--gold);
    padding: 36px 28px;
    position: sticky;
    top: 100px;
  }

  .sidebar-card h4 {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .sidebar-card ul { list-style: none; }

  .sidebar-card li {
    font-size: 14px;
    color: var(--text-muted);
    padding: 8px 0;
    border-bottom: 1px solid rgba(14, 26, 58, 0.06);
    line-height: 1.6;
  }

  .sidebar-cta {
    display: block;
    text-align: center;
    background: var(--navy);
    color: var(--pearl);
    padding: 14px 24px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    margin-top: 28px;
    transition: background 0.3s;
  }

  .sidebar-cta:hover { background: var(--purple); }

  /* ── PARTNER ── */
  .partner {
    padding: 90px 0;
    background: var(--purple);
    color: var(--pearl);
  }

  .narrow { max-width: 720px; margin: 0 auto; text-align: center; }

  .partner .eyebrow { margin-bottom: 16px; color: #E8D9B5; }

  .partner h2 {
    font-size: 30px;
    color: var(--pearl);
    margin-bottom: 20px;
  }

  .partner p {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(250, 246, 239, 0.82);
  }

  /* ── CTA ── */
  .page-cta {
    padding: 100px 0;
    background: var(--navy);
    color: var(--pearl);
  }

  .page-cta h2 {
    font-size: clamp(28px, 3.5vw, 40px);
    color: var(--pearl);
    margin-bottom: 16px;
  }

  .page-cta p {
    font-size: 17px;
    color: rgba(250, 246, 239, 0.75);
    margin-bottom: 36px;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--gold);
    color: var(--pearl);
    padding: 16px 32px;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    transition: all 0.3s;
  }

  .cta-btn:hover { background: var(--gold); color: var(--navy); }
  .cta-btn::after { content: '→'; font-size: 16px; letter-spacing: 0; }

  @media (max-width: 880px) {
    .detail-grid { grid-template-columns: 1fr; gap: 50px; }
    .sidebar-card { position: static; }
  }

  @media (max-width: 540px) {
    .page-hero { padding: 70px 0 50px; }
    .page-hero h1 { font-size: 30px; }
    .detail { padding: 60px 0; }
  }
</style>
