---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Behavioral & Harmony Coaching · Riviera & Ridge"
  description="Qualified behavioural guidance for children who need a calmer voice or a different rhythm. 20 years of professional practice."
>
  <Nav slot="header" />

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Behavioral & Harmony Coaching",
      "description": "Qualified behavioural guidance for children who need a calmer voice or a different rhythm. 20 years of professional practice.",
      "provider": {
        "@type": "ProfessionalService",
        "name": "Riviera & Ridge",
        "url": "https://rivieraandridge.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Zermatt",
          "addressRegion": "Valais",
          "addressCountry": "CH"
        }
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Zermatt"
        },
        {
          "@type": "Country",
          "name": "Switzerland"
        }
      ],
      "serviceType": "Behavioural Coaching"
    }
  </script>

  <!-- ═══════════ HERO ═══════════ -->
// ... existing code ...


  <!-- ═══════════ HERO ═══════════ -->
  <section class="page-hero">
    <div class="container">
      <span class="tier-label">Tier II</span>
      <div class="eyebrow">For children who need a different approach</div>
      <h1>Calm that holds. <em>Structure that carries.</em></h1>
      <p class="hero-lead">
        Qualified behavioural guidance for children who respond to calm authority
        — rooted in 20 years of professional practice as an educator.
      </p>
    </div>
  </section>

  <!-- ═══════════ DETAIL ═══════════ -->
  <section class="detail">
    <div class="container detail-grid">
      <div class="detail-main">
        <h2>What this looks like</h2>
        <ul class="feature-list">
          <li>Engagements from days to weeks, integrated into the family's daily rhythm.</li>
          <li>Behavioural guidance: clear frames, consistent boundaries, age-appropriate emotional regulation support.</li>
          <li>Conflict resolution within sibling groups or between children and existing staff.</li>
          <li>Developmental observation and enrichment — with a focus on strengths, not labels.</li>
          <li>Mindfulness and yoga-based techniques where appropriate (certified children's yoga teacher, 3HO).</li>
        </ul>

        <h2>Typical fit</h2>
        <ul class="feature-list">
          <li>Children who respond to calm authority rather than entertainment.</li>
          <li>Families seeking a qualified educator's perspective on challenging dynamics — pedagogical depth grounded in decades of practice.</li>
          <li>Households where existing care works day-to-day, but particular situations call for a different skillset.</li>
        </ul>
      </div>

      <aside class="detail-sidebar">
        <div class="sidebar-card">
          <h4>Indicative frame</h4>
          <ul>
            <li>Rates confirmed after the qualifying conversation</li>
            <li>Available standalone or as add-on to Tier&nbsp;I</li>
            <li>Languages: EN · DE · FR</li>
          </ul>
          <a href="/contact" class="sidebar-cta">Request a conversation</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- ═══════════ SCOPE NOTE ═══════════ -->
  <section class="scope-note">
    <div class="container narrow">
      <div class="eyebrow">A note on scope</div>
      <h2>Professional childcare — with depth.</h2>
      <p>
        The work stays rooted in professional childcare and educational practice,
        delivered by a <em>staatlich geprüfte Erzieherin</em> trained to observe,
        adapt, and hold the frame. Where specialist support is needed,
        Riviera &amp; Ridge works respectfully alongside existing professionals.
      </p>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════ -->
  <section class="page-cta">
    <div class="container" style="text-align:center">
      <h2>When children feel emotionally safe, everything else becomes easier.</h2>
      <p>Every engagement begins with a qualifying conversation.</p>
      <a href="/contact" class="cta-btn">Request a conversation</a>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .page-hero {
    background: var(--navy);
    color: var(--pearl);
    padding: 100px 0 80px;
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(34px, 5vw, 52px);
    font-weight: 300;
    max-width: 780px;
    margin: 0 auto 24px;
  }

  .page-hero h1 em { font-style: italic; color: #E8D9B5; font-weight: 300; }
  .page-hero .eyebrow { margin-bottom: 20px; color: var(--gold); }

  .tier-label {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(184, 137, 58, 0.4);
    padding: 6px 18px;
    margin-bottom: 20px;
  }

  .hero-lead {
    font-size: 17px;
    color: rgba(250, 246, 239, 0.75);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .detail { padding: 100px 0; }

  .detail-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .detail-main h2 {
    font-size: 28px;
    color: var(--navy);
    margin: 50px 0 24px;
  }

  .detail-main h2:first-child { margin-top: 0; }

  .feature-list { list-style: none; }

  .feature-list li {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-muted);
    padding: 10px 0 10px 24px;
    position: relative;
    border-bottom: 1px solid rgba(14, 26, 58, 0.06);
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20px;
    width: 10px;
    height: 1px;
    background: var(--gold);
  }

  .sidebar-card {
    background: var(--pearl-card);
    border-top: 2px solid var(--gold);
    padding: 36px 28px;
    position: sticky;
    top: 100px;
  }

  .sidebar-card h4 {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .sidebar-card ul { list-style: none; }

  .sidebar-card li {
    font-size: 14px;
    color: var(--text-muted);
    padding: 8px 0;
    border-bottom: 1px solid rgba(14, 26, 58, 0.06);
    line-height: 1.6;
  }

  .sidebar-cta {
    display: block;
    text-align: center;
    background: var(--navy);
    color: var(--pearl);
    padding: 14px 24px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    margin-top: 28px;
    transition: background 0.3s;
  }

  .sidebar-cta:hover { background: var(--purple); }

  .scope-note {
    padding: 90px 0;
    background: var(--purple);
    color: var(--pearl);
  }

  .narrow { max-width: 720px; margin: 0 auto; text-align: center; }

  .scope-note .eyebrow { margin-bottom: 16px; color: #E8D9B5; }

  .scope-note h2 {
    font-size: 30px;
    color: var(--pearl);
    margin-bottom: 20px;
  }

  .scope-note p {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(250, 246, 239, 0.82);
  }

  .scope-note em { font-style: italic; }

  .page-cta {
    padding: 100px 0;
    background: var(--navy);
    color: var(--pearl);
  }

  .page-cta h2 {
    font-size: clamp(28px, 3.5vw, 40px);
    color: var(--pearl);
    margin-bottom: 16px;
  }

  .page-cta p {
    font-size: 17px;
    color: rgba(250, 246, 239, 0.75);
    margin-bottom: 36px;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--gold);
    color: var(--pearl);
    padding: 16px 32px;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    transition: all 0.3s;
  }

  .cta-btn:hover { background: var(--gold); color: var(--navy); }
  .cta-btn::after { content: '→'; font-size: 16px; letter-spacing: 0; }

  @media (max-width: 880px) {
    .detail-grid { grid-template-columns: 1fr; gap: 50px; }
    .sidebar-card { position: static; }
  }

  @media (max-width: 540px) {
    .page-hero { padding: 70px 0 50px; }
    .page-hero h1 { font-size: 30px; }
    .detail { padding: 60px 0; }
  }
</style>
