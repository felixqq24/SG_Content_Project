---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/images/hero.jpg';
import aboutImg from '../assets/images/about.jpg';
import contactImg from '../assets/images/contact.jpg';
---

<Base title="Riviera & Ridge · Premium Nanny · International">
  <Nav slot="header" />

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Riviera & Ridge",
      "image": "https://rivieraandridge.com/assets/images/hero.jpg",
      "url": "https://rivieraandridge.com",
      "telephone": "+41 00 000 00 00",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Zermatt",
        "addressLocality": "Zermatt",
        "addressRegion": "Valais",
        "postalCode": "3920",
        "addressCountry": "CH"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 46.0207,
        "longitude": 7.7803
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday"
        ],
        "opens": "09:00",
        "closes": "18:00"
      },
      "description": "Premium Nanny and travel expert based in Zermatt, Switzerland. Providing high-end childcare, ski instruction, and yoga for international families."
    }
  </script>

  <!-- ═══════════ HERO ═══════════ -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="eyebrow">Premium Nanny · Based in Switzerland · Available Worldwide</div>
        <h1>Presence over <em>performance.</em></h1>
        <p class="lede">
          A state-certified educator, ski and yoga instructor — a mother of four
          who understands family life beyond theory. For internationally mobile
          families who value calm, attention, and genuine presence.
        </p>
        <a href="/contact" class="hero-cta">Request a conversation</a>
        <div class="hero-meta">
          <span>Based in Switzerland</span>
          <span>Weekly, monthly &amp; travel engagements</span>
          <span>EN · DE · FR</span>
        </div>
      </div>
      <div class="hero-photo">
        <Image
          src={heroImg}
          alt="Portrait — Riviera & Ridge"
          width={420}
          quality={80}
          format="webp"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════ SERVICES ═══════════ -->
  <section class="pillars" id="services">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">A bespoke triple-tier service</div>
        <h2>Three pillars of support for your family.</h2>
        <p>Every engagement begins with a qualifying conversation. Indicative rates from CHF, confirmed after we have spoken.</p>
      </div>
      <div class="pillar-grid">
        <article class="pillar-card">
          <span class="pillar-num">I</span>
          <h3>Active Travel &amp; Alpine Expert</h3>
          <p>
            From snowy mornings in Zermatt to long-haul travel days —
            a child who feels secure travels differently. One qualified educator
            with outdoor competence, across mountains and time zones.
          </p>
          <a href="/services/travel-alpine" class="more">Learn more</a>
        </article>
        <article class="pillar-card">
          <span class="pillar-num">II</span>
          <h3>Behavioral &amp; Harmony Coaching</h3>
          <p>
            Some children respond to a different rhythm, a clearer frame, or simply
            someone grounded. The work stays rooted in professional childcare and
            educational practice — with the depth that makes a difference.
          </p>
          <a href="/services/behavioral-harmony" class="more">Learn more</a>
        </article>
        <article class="pillar-card">
          <span class="pillar-num">III</span>
          <h3>Elite Relief &amp; Emergency Support</h3>
          <p>
            Qualified, discreet cover when your live-in nanny is unavailable — or when
            the situation calls for someone who can step in and hold the frame at short notice.
          </p>
          <a href="/services/elite-relief" class="more">Learn more</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════ ABOUT ═══════════ -->
  <section class="about" id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-photo">
          <Image
            src={aboutImg}
            alt="About — Riviera & Ridge"
            width={520}
            quality={80}
            format="webp"
          />
        </div>
        <div class="about-text">
          <div class="eyebrow">The person behind Riviera &amp; Ridge</div>
          <h2>One qualified person. <em>A rare combination.</em></h2>
          <p>
            A <em>staatlich geprüfte Erzieherin</em> (state-certified early-childhood
            educator) with ski-instructor competence and a deep yoga practice.
            Professional training matters. So does raising four children of your
            own — the steadiness that comes from both shows in how children
            settle, often within minutes.
          </p>
          <p>
            Children notice atmosphere before adults do. Some need movement before
            they can sit still. Others find their words only after a stretch of
            quiet. Continuity is underrated — especially while travelling.
          </p>
          <ul class="qual-list">
            <li>State-certified early-childhood educator</li>
            <li>Certified ski instructor</li>
            <li>Yoga teacher (3HO, ~400 h)</li>
            <li>Children's yoga &amp; yoga coach</li>
            <li>Forest-kindergarten experience</li>
            <li>Mother of four — family life beyond theory</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ QUOTE ═══════════ -->
  <section class="quote-section">
    <div class="container">
      <blockquote class="brand-statement">
        When children feel emotionally safe, everything else becomes easier.
      </blockquote>
      <div class="quote-pillars">
        <span>Calm</span>
        <span>Presence</span>
        <span>Structure</span>
        <span>Trust</span>
        <span>Regulation</span>
      </div>
    </div>
  </section>

  <!-- ═══════════ TESTIMONIALS ═══════════ -->
  <section class="testimonials" id="testimonials">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">Families who have worked with us</div>
        <h2>Trusted across borders — <em>remembered for the details.</em></h2>
      </div>
      <div class="testimonial-grid">
        <blockquote class="testimonial-card">
          <p>&ldquo;[Testimonial — SG to provide from family references]&rdquo;</p>
          <footer><cite>Family &middot; Location</cite></footer>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>&ldquo;[Testimonial — SG to provide from family references]&rdquo;</p>
          <footer><cite>Family &middot; Location</cite></footer>
        </blockquote>
        <blockquote class="testimonial-card">
          <p>&ldquo;[Testimonial — SG to provide from family references]&rdquo;</p>
          <footer><cite>Family &middot; Location</cite></footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══════════ PRICING ═══════════ -->
  <section class="pricing" id="pricing">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">Indicative Rates</div>
        <h2>Tailored to your family's needs.</h2>
        <p>Every collaboration is individually designed based on scope, travel, responsibility, and location.</p>
      </div>
      <div class="pricing-grid">
        <div class="price-card">
          <div class="tier-label">Hourly</div>
          <h3>Flexible Engagements</h3>
          <div class="price">from CHF 65 <small>/ hour</small></div>
          <ul>
            <li>Daily childcare</li>
            <li>Lesson &amp; activity accompaniment</li>
            <li>Travel days &amp; transitions</li>
            <li>Light concierge duties</li>
            <li>Evening support by arrangement</li>
          </ul>
        </div>
        <div class="price-card featured">
          <div class="tier-label">Weekly</div>
          <h3>Travel &amp; Alpine Packages</h3>
          <div class="price">CHF 4,800–12,000 <small>/ week</small></div>
          <ul>
            <li>Full-day premium care</li>
            <li>Ski, outdoor &amp; wellness</li>
            <li>Multi-location support</li>
            <li>Flexible hours</li>
            <li>Household coordination</li>
            <li>Evening coverage</li>
          </ul>
        </div>
        <div class="price-card">
          <div class="tier-label">Long-term</div>
          <h3>Monthly &amp; Seasonal</h3>
          <div class="price">from CHF 8,500 <small>/ month</small></div>
          <ul>
            <li>Continuity across weeks and months</li>
            <li>International travel readiness</li>
            <li>Complete day management</li>
            <li>Emotional regulation support</li>
            <li>Private wellness &amp; movement</li>
            <li>UHNW annual arrangements on request</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ CONTACT ═══════════ -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-text">
          <div class="eyebrow">Begin here</div>
          <h2>Every engagement begins with a conversation.</h2>
          <p>
            The qualifying conversation lets us understand your family — and lets
            you understand who you are entrusting your children to. It is unhurried,
            confidential, and without obligation.
          </p>
          <p>
            Before working together, we take time to see whether the fit feels
            right — for both sides. When you write, call, or book — you reach the
            person who leads the engagement. Where needed, a small circle of
            hand-picked, qualified professionals supports the work in the same spirit.
          </p>
          <a href="/contact" class="contact-cta">Request a qualifying call</a>
          <div class="contact-channels">
            <h4>Or reach us directly</h4>
            <ul>
              <li>hello@rivieraandridge.com</li>
              <li>Mon–Fri, 9–18 CET</li>
            </ul>
          </div>
        </div>
        <div class="contact-photo">
          <Image
            src={contactImg}
            alt="Contact — Riviera & Ridge"
            width={400}
            quality={80}
            format="webp"
          />
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  /* ── HERO ── */
  .hero {
    background: var(--navy);
    color: var(--pearl);
    padding: 80px 0 100px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 75% 30%, rgba(74, 44, 109, 0.55), transparent 55%),
      radial-gradient(ellipse at 20% 80%, rgba(184, 137, 58, 0.10), transparent 50%);
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-text h1 {
    font-size: clamp(34px, 5vw, 62px);
    font-weight: 300;
    line-height: 1.08;
    margin-bottom: 28px;
    color: var(--pearl);
  }

  .hero-text h1 em {
    font-style: italic;
    color: #E8D9B5;
    font-weight: 300;
  }

  .lede {
    font-size: 18px;
    font-weight: 300;
    line-height: 1.65;
    max-width: 540px;
    color: rgba(250, 246, 239, 0.82);
    margin-bottom: 40px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--gold);
    color: var(--pearl);
    padding: 16px 32px;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    transition: all 0.3s;
  }

  .hero-cta:hover {
    background: var(--gold);
    color: var(--navy);
  }

  .hero-cta::after {
    content: '→';
    font-size: 16px;
    letter-spacing: 0;
  }

  .hero-photo {
    position: relative;
  }

  .hero-photo img {
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center top;
    border: 1px solid var(--hairline);
  }

  .hero-photo::after {
    content: '';
    position: absolute;
    bottom: -12px;
    right: -12px;
    width: 100%;
    aspect-ratio: 4/5;
    border: 1px solid var(--gold);
    z-index: -1;
  }

  .hero-meta {
    display: flex;
    gap: 48px;
    margin-top: 50px;
    padding-top: 30px;
    border-top: 1px solid rgba(184, 137, 58, 0.25);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(250, 246, 239, 0.65);
  }

  .hero-meta span::before {
    content: '·';
    color: var(--gold);
    margin-right: 14px;
  }

  .hero-meta span:first-child::before {
    display: none;
  }

  /* ── PILLARS ── */
  .pillars {
    padding: 110px 0 100px;
  }

  .section-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 70px;
  }

  .section-head .eyebrow {
    margin-bottom: 18px;
  }

  .section-head h2 {
    font-size: clamp(34px, 4.2vw, 48px);
    margin-bottom: 22px;
    color: var(--navy);
  }

  .section-head p {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .pillar-card {
    background: var(--pearl-card);
    padding: 44px 36px 40px;
    border-top: 2px solid var(--gold);
    transition: transform 0.3s ease;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
  }

  .pillar-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    color: var(--gold);
    letter-spacing: 0.3em;
    margin-bottom: 18px;
    display: block;
  }

  .pillar-card h3 {
    font-size: 26px;
    color: var(--navy);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .pillar-card p {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .more {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--purple);
    font-weight: 500;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 4px;
  }

  /* ── ABOUT ── */
  .about {
    background: var(--purple);
    color: var(--pearl);
    padding: 110px 0;
    position: relative;
  }

  .about::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 1px;
    background: var(--gold);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: start;
  }

  .about-photo {
    position: relative;
  }

  .about-photo img {
    aspect-ratio: 4/5;
    object-fit: cover;
    object-position: center top;
  }

  .about-photo::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: -10px;
    width: 100%;
    height: 100%;
    border: 1px solid var(--gold);
    z-index: -1;
  }

  .about-text .eyebrow {
    color: #E8D9B5;
    margin-bottom: 18px;
  }

  .about-text h2 {
    font-size: clamp(32px, 3.8vw, 44px);
    margin-bottom: 28px;
    color: var(--pearl);
  }

  .about-text h2 em {
    font-style: italic;
    color: #E8D9B5;
    font-weight: 400;
  }

  .about-text p {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(250, 246, 239, 0.85);
    margin-bottom: 18px;
    max-width: 560px;
  }

  .qual-list {
    list-style: none;
    margin-top: 36px;
    padding-top: 30px;
    border-top: 1px solid rgba(184, 137, 58, 0.35);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px 32px;
  }

  .qual-list li {
    font-size: 13px;
    letter-spacing: 0.04em;
    color: rgba(250, 246, 239, 0.9);
    padding-left: 18px;
    position: relative;
  }

  .qual-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 8px;
    height: 1px;
    background: var(--gold);
  }

  /* ── QUOTE ── */
  .quote-section {
    padding: 110px 0;
    text-align: center;
  }

  .quote-section blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(26px, 3.5vw, 38px);
    line-height: 1.4;
    color: var(--navy);
    font-weight: 300;
    font-style: italic;
    max-width: 820px;
    margin: 0 auto;
  }

  .quote-section blockquote::before {
    content: '\201C';
    display: block;
    font-size: 80px;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
    font-style: normal;
    font-weight: 400;
  }

  .brand-statement {
    font-size: clamp(30px, 4vw, 44px) !important;
  }

  .quote-pillars {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .quote-pillars span {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
    position: relative;
    padding: 0 4px;
  }

  .quote-pillars span::before {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 1px;
    background: var(--gold);
  }

  .quote-attr {
    margin-top: 36px;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .quote-attr::before {
    content: '— ';
    color: var(--gold);
  }

  /* ── TESTIMONIALS ── */
  .testimonials {
    padding: 110px 0 100px;
    background: var(--pearl-card);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .testimonial-card {
    background: #fff;
    padding: 44px 32px 36px;
    border-top: 2px solid var(--gold);
    position: relative;
  }

  .testimonial-card::before {
    content: '\201C';
    font-family: 'Cormorant Garamond', serif;
    font-size: 60px;
    color: var(--gold);
    line-height: 1;
    position: absolute;
    top: 28px;
    left: 28px;
    opacity: 0.35;
  }

  .testimonial-card p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--navy);
    font-style: italic;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .testimonial-card footer {
    font-size: 13px;
    color: var(--text-muted);
  }

  .testimonial-card cite {
    font-style: normal;
    font-weight: 500;
    display: block;
    letter-spacing: 0.04em;
  }

  /* ── PRICING ── */
  .pricing {
    padding: 110px 0 100px;
    background: var(--navy);
    color: var(--pearl);
  }

  .pricing .section-head h2 {
    color: var(--pearl);
  }

  .pricing .section-head p {
    color: rgba(250, 246, 239, 0.7);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .price-card {
    background: rgba(250, 246, 239, 0.04);
    border: 1px solid rgba(184, 137, 58, 0.3);
    padding: 44px 32px 40px;
    transition: border-color 0.3s;
  }

  .price-card:hover {
    border-color: var(--gold);
  }

  .tier-label {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
  }

  .price-card h3 {
    font-size: 24px;
    color: var(--pearl);
    margin-bottom: 14px;
  }

  .price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px;
    color: #E8D9B5;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .price small {
    font-size: 14px;
    color: rgba(250, 246, 239, 0.6);
    font-family: 'Inter', sans-serif;
  }

  .price-card ul {
    list-style: none;
    margin-top: 20px;
  }

  .price-card li {
    font-size: 13px;
    color: rgba(250, 246, 239, 0.75);
    padding: 7px 0 7px 16px;
    position: relative;
    border-bottom: 1px solid rgba(250, 246, 239, 0.06);
  }

  .price-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 6px;
    height: 1px;
    background: var(--gold);
  }

  .featured {
    border-color: var(--gold);
    background: rgba(184, 137, 58, 0.08);
  }

  /* ── CONTACT ── */
  .contact {
    padding: 110px 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-text h2 {
    font-size: clamp(30px, 3.5vw, 42px);
    margin-bottom: 24px;
    color: var(--navy);
  }

  .contact-text p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-muted);
    margin-bottom: 16px;
    max-width: 480px;
  }

  .contact-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--navy);
    color: var(--pearl);
    padding: 16px 32px;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    margin-top: 20px;
    transition: all 0.3s;
  }

  .contact-cta:hover {
    background: var(--purple);
  }

  .contact-cta::after {
    content: '→';
    font-size: 16px;
    letter-spacing: 0;
  }

  .contact-photo img {
    max-width: 400px;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center top;
  }

  .contact-channels {
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--hairline);
  }

  .contact-channels h4 {
